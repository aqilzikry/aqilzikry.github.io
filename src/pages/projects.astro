---
import { info } from '@data';

import ProjectsWrapper from '@components/general/ProjectsWrapper.astro';
import SectionHeader from '@components/general/SectionHeader.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import { projectImages } from '@utils/images';

const projects = info.projects;
const projectDataMap = Object.fromEntries(projects.map((project) => [project.id, project]));

const projectImagePaths = [...new Set(projects.flatMap((project) => [project.thumbnail, ...project.images]))];

// Create a mapping of original paths to resolved image URLs in parallel.
const imageUrlMap = Object.fromEntries(
  await Promise.all(
    projectImagePaths
      .filter((imagePath) => projectImages[imagePath])
      .map(async (imagePath) => {
        const resolvedImage = await projectImages[imagePath]();
        return [imagePath, resolvedImage.default.src];
      })
  )
);
---

<BaseLayout
  title='Projects'
  description='The full lineup of things I have shipped.'
  ogImageUrl='/assets/images/og-image.webp'
>
      <SectionHeader
        as='h1'
        title='Projects'
        subtitle='The full lineup of things I have shipped'
        class='mb-8'
        transition:animate='slide'
      />
      <ProjectsWrapper projects={projects} />

      <!-- Project Overlay -->
      <div
        id='project-overlay'
        class='fixed inset-0 overlay-scrim z-50 items-center justify-center p-4 hidden'
      >
        <!-- Close button -->
        <button
          id='close-overlay'
          class='absolute top-6 right-6 text-white hover:text-accent transition-colors duration-200 z-10'
          aria-label='Close overlay'
        >
          <svg
            xmlns='http://www.w3.org/2000/svg'
            width='32'
            height='32'
            viewBox='0 0 24 24'
            fill='none'
            stroke='currentColor'
            stroke-width='2'
            stroke-linecap='round'
            stroke-linejoin='round'
          >
            <line x1='18' y1='6' x2='6' y2='18'></line>
            <line x1='6' y1='6' x2='18' y2='18'></line>
          </svg>
        </button>

        <!-- Overlay content -->
        <div class='max-w-4xl mx-auto surface-card overflow-hidden'>
          <!-- Carousel container -->
          <div class='relative'>
            <!-- Images -->
            <div id='carousel-container' class='overflow-hidden'>
              <div id='carousel-track' class='flex transition-transform duration-300 ease-in-out'>
                <!-- Images will be dynamically populated -->
              </div>
            </div>

            <!-- Navigation arrows -->
            <button
              id='prev-btn'
              class='absolute left-4 top-1/2 transform -translate-y-1/2 glass-button p-2 hidden'
              aria-label='Previous image'
            >
              <svg
                xmlns='http://www.w3.org/2000/svg'
                width='24'
                height='24'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
              >
                <polyline points='15,18 9,12 15,6'></polyline>
              </svg>
            </button>

            <button
              id='next-btn'
              class='absolute right-4 top-1/2 transform -translate-y-1/2 glass-button p-2 hidden'
              aria-label='Next image'
            >
              <svg
                xmlns='http://www.w3.org/2000/svg'
                width='24'
                height='24'
                viewBox='0 0 24 24'
                fill='none'
                stroke='currentColor'
                stroke-width='2'
                stroke-linecap='round'
                stroke-linejoin='round'
              >
                <polyline points='9,18 15,12 9,6'></polyline>
              </svg>
            </button>

            <!-- Dots indicator -->
            <div
              id='dots-container'
              class='absolute bottom-4 left-1/2 transform -translate-x-1/2 carousel-dots-row space-x-2 hidden'
            >
              <!-- Dots will be dynamically populated -->
            </div>
          </div>

          <!-- Content -->
          <div class='p-6'>
            <div class='flex items-center justify-between mb-4'>
              <h2 id='overlay-title' class='text-2xl font-bold text-text-strong dark:text-light'>
                <!-- Title will be dynamically populated -->
              </h2>

              <!-- External links -->
              <div id='overlay-links' class='flex space-x-2'>
                <!-- Links will be dynamically populated -->
              </div>
            </div>

            <p id='overlay-description' class='text-text-body dark:text-light leading-relaxed'>
              <!-- Description will be dynamically populated -->
            </p>
          </div>
        </div>
      </div>

  <script
    is:inline
    type='application/json'
    id='projects-page-data'
    set:html={JSON.stringify({ projectDataMap, imageUrlMap })}
  />

  <script>
    import { initProjectsOverlay } from '../scripts/projects-overlay';
    initProjectsOverlay();
  </script>

  <style>
    #project-overlay {
      animation: fadeIn 0.3s ease-in-out;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }
  </style>
</BaseLayout>
