---
import SectionHeader from '@components/general/SectionHeader.astro';
import BaseLayout from '@layouts/BaseLayout.astro';
import Base64Converter from '@components/tools/Base64Converter.astro';
import BudgetCalculator from '@components/tools/BudgetCalculator.astro';
import ColorConverter from '@components/tools/ColorConverter.astro';
import JsonXmlValidator from '@components/tools/JsonXmlValidator.astro';
import JwtDecoder from '@components/tools/JwtDecoder.astro';
import DeadlineCountdown from '@components/tools/DeadlineCountdown.astro';
import TimezoneConverter from '@components/tools/TimezoneConverter.astro';
import UnitPriceCalculator from '@components/tools/UnitPriceCalculator.astro';
import UrlConverter from '@components/tools/UrlConverter.astro';
---

<BaseLayout
  title='Tools'
  description='Handy bits I use more than I probably should.'
  ogImageUrl='/assets/images/og-image.webp'
>
      <SectionHeader
        as='h1'
        title='Tools'
        subtitle='Handy bits I use more than I probably should'
        class='mb-8'
        transition:animate='slide'
      />

      <!-- Tab Navigation -->
      <div class='mb-8'>
        <nav class='w-fit space-x-1 glass-surface rounded-brand p-1' role='tablist'>
          <button
            id='tab-development'
            class='tab-button px-4 py-2 text-sm font-medium rounded-control transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-accent/50'
            role='tab'
            aria-selected='true'
            aria-controls='panel-development'
            data-tab='development'
          >
            <span class='flex items-center justify-center gap-2'>
              <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4'></path>
              </svg>
              Development
            </span>
          </button>
          <button
            id='tab-productivity'
            class='tab-button px-4 py-2 text-sm font-medium rounded-control transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-accent/50'
            role='tab'
            aria-selected='false'
            aria-controls='panel-productivity'
            data-tab='productivity'
          >
            <span class='flex items-center justify-center gap-2'>
              <svg class='w-4 h-4' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                <path
                  stroke-linecap='round'
                  stroke-linejoin='round'
                  stroke-width='2'
                  d='M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z'
                ></path>
              </svg>
              Productivity
            </span>
          </button>
        </nav>
      </div>

      <!-- Tab Panels -->
      <div class='tab-content'>
        <!-- Development Tools Panel -->
        <div id='panel-development' class='tab-panel' role='tabpanel' aria-labelledby='tab-development'>
          <!-- Development Tools Pills -->
          <div class='mb-6'>
            <nav class='flex flex-wrap gap-2' role='tablist'>
              <button class='pill-button active' data-tool='color-converter' data-category='development'>
                <span class='flex items-center gap-2'> Color Converter </span>
              </button>
              <button class='pill-button' data-tool='json-xml-validator' data-category='development'>
                <span class='flex items-center gap-2'> JSON & XML Validator </span>
              </button>
              <button class='pill-button' data-tool='jwt-decoder' data-category='development'>
                <span class='flex items-center gap-2'> JWT Decoder </span>
              </button>
              <button class='pill-button' data-tool='base64-converter' data-category='development'>
                <span class='flex items-center gap-2'> Base64 Encode/Decode </span>
              </button>
              <button class='pill-button' data-tool='url-converter' data-category='development'>
                <span class='flex items-center gap-2'> URL Encode/Decode </span>
              </button>
            </nav>
          </div>

          <!-- Development Tools Content -->
          <div class='tool-content'>
            <!-- Color Converter Tool -->
            <div id='tool-color-converter' class='tool-panel' data-category='development'>
              <div
                class='surface-card p-6 max-w-2xl'
              >
                <div class='flex items-center gap-3 mb-4'>
                  <div class='p-2 icon-badge'>
                    <svg
                      class='w-5 h-5'
                      fill='none'
                      stroke='currentColor'
                      viewBox='0 0 24 24'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zM21 5a2 2 0 00-2-2h-4a2 2 0 00-2 2v12a4 4 0 004 4h4a2 2 0 002-2V5z'
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <h2 class='text-2xl font-outfit text-dark dark:text-light'>Color Converter</h2>
                    <p class='text-text-muted dark:text-custom-gray-300 text-sm'>
                      HEX, RGB, HSL — pick your format and go
                    </p>
                  </div>
                </div>
                <ColorConverter />
              </div>
            </div>

            <!-- JSON & XML Validator Tool -->
            <div id='tool-json-xml-validator' class='tool-panel hidden' data-category='development'>
              <div
                class='surface-card p-6'
              >
                <div class='flex items-center gap-3 mb-4'>
                  <div class='p-2 icon-badge-success'>
                    <svg
                      class='w-5 h-5'
                      fill='none'
                      stroke='currentColor'
                      viewBox='0 0 24 24'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z'
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <h2 class='text-2xl font-outfit text-dark dark:text-light'>JSON & XML Validator</h2>
                    <p class='text-text-muted dark:text-custom-gray-300 text-sm'>
                      Paste it in, find out if it actually works
                    </p>
                  </div>
                </div>
                <JsonXmlValidator />
              </div>
            </div>

            <!-- JWT Decoder Tool -->
            <div id='tool-jwt-decoder' class='tool-panel hidden' data-category='development'>
              <div class='surface-card p-6'>
                <div class='flex items-center gap-3 mb-4'>
                  <div class='p-2 icon-badge-violet'>
                    <svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z'
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <h2 class='text-2xl font-outfit text-dark dark:text-light'>JWT Decoder</h2>
                    <p class='text-text-muted dark:text-custom-gray-300 text-sm'>
                      Paste a token, see what's inside
                    </p>
                  </div>
                </div>
                <JwtDecoder />
              </div>
            </div>

            <!-- Base64 Encode/Decode Tool -->
            <div id='tool-base64-converter' class='tool-panel hidden' data-category='development'>
              <div class='surface-card p-6 max-w-2xl'>
                <div class='flex items-center gap-3 mb-4'>
                  <div class='p-2 icon-badge-indigo'>
                    <svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4'
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <h2 class='text-2xl font-outfit text-dark dark:text-light'>Base64 Encode/Decode</h2>
                    <p class='text-text-muted dark:text-custom-gray-300 text-sm'>
                      Flip between plain text and Base64
                    </p>
                  </div>
                </div>
                <Base64Converter />
              </div>
            </div>

            <!-- URL Encode/Decode Tool -->
            <div id='tool-url-converter' class='tool-panel hidden' data-category='development'>
              <div class='surface-card p-6 max-w-2xl'>
                <div class='flex items-center gap-3 mb-4'>
                  <div class='p-2 icon-badge-success'>
                    <svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1'
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <h2 class='text-2xl font-outfit text-dark dark:text-light'>URL Encode/Decode</h2>
                    <p class='text-text-muted dark:text-custom-gray-300 text-sm'>
                      Percent-encode or decode URL strings
                    </p>
                  </div>
                </div>
                <UrlConverter />
              </div>
            </div>
          </div>
        </div>

        <!-- Productivity Tools Panel -->
        <div id='panel-productivity' class='tab-panel hidden' role='tabpanel' aria-labelledby='tab-productivity'>
          <!-- Productivity Tools Pills -->
          <div class='mb-6'>
            <nav class='flex flex-wrap gap-2' role='tablist'>
              <button class='pill-button active' data-tool='budget-calculator' data-category='productivity'>
                <span class='flex items-center gap-2'> 50/30/20 Budget Calculator </span>
              </button>
              <button class='pill-button' data-tool='timezone-converter' data-category='productivity'>
                <span class='flex items-center gap-2'> Timezone Converter </span>
              </button>
              <button class='pill-button' data-tool='unit-price-calculator' data-category='productivity'>
                <span class='flex items-center gap-2'> Unit Price Calculator </span>
              </button>
              <button class='pill-button' data-tool='deadline-countdown' data-category='productivity'>
                <span class='flex items-center gap-2'> Deadline Countdown </span>
              </button>
            </nav>
          </div>

          <!-- Productivity Tools Content -->
          <div class='tool-content'>
            <!-- Budget Calculator Tool -->
            <div id='tool-budget-calculator' class='tool-panel' data-category='productivity'>
              <div
                class='surface-card p-6 max-w-2xl'
              >
                <div class='flex items-center gap-3 mb-4'>
                  <div class='p-2 icon-badge-violet'>
                    <svg
                      class='w-5 h-5'
                      fill='none'
                      stroke='currentColor'
                      viewBox='0 0 24 24'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z'
                      ></path>
                    </svg>
                  </div>
                  <div>
                    <h2 class='text-2xl font-outfit text-dark dark:text-light'>50/30/20 Budget Calculator</h2>
                    <p class='text-text-muted dark:text-custom-gray-300 text-sm'>
                      Needs, wants, savings — all sorted out
                    </p>
                  </div>
                </div>
                <BudgetCalculator />
              </div>
            </div>

            <!-- Timezone Converter Tool -->
            <div id='tool-timezone-converter' class='tool-panel hidden' data-category='productivity'>
              <div
                class='surface-card p-6'
              >
                <div class='flex items-center gap-3 mb-4'>
                  <div class='p-2 icon-badge-indigo'>
                    <svg
                      class='w-5 h-5'
                      fill='none'
                      stroke='currentColor'
                      viewBox='0 0 24 24'
                    >
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'></path>
                    </svg>
                  </div>
                  <div>
                    <h2 class='text-2xl font-outfit text-dark dark:text-light'>Timezone Converter</h2>
                    <p class='text-text-muted dark:text-custom-gray-300 text-sm'>
                      For when "what time is it there?" gets old
                    </p>
                  </div>
                </div>
                <TimezoneConverter />
              </div>
            </div>

            <!-- Unit Price Calculator Tool -->
            <div id='tool-unit-price-calculator' class='tool-panel hidden' data-category='productivity'>
              <div class='surface-card p-6 max-w-3xl'>
                <div class='flex items-center gap-3 mb-4'>
                  <div class='p-2 icon-badge-success'>
                    <svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M9 14l2-2 4 4m5-5a9 9 0 11-18 0 9 9 0 0118 0z'></path>
                    </svg>
                  </div>
                  <div>
                    <h2 class='text-2xl font-outfit text-dark dark:text-light'>Unit Price Calculator</h2>
                    <p class='text-text-muted dark:text-custom-gray-300 text-sm'>
                      Compare two options by what they really cost per unit
                    </p>
                  </div>
                </div>
                <UnitPriceCalculator />
              </div>
            </div>

            <!-- Deadline Countdown Tool -->
            <div id='tool-deadline-countdown' class='tool-panel hidden' data-category='productivity'>
              <div class='surface-card p-6 max-w-3xl'>
                <div class='flex items-center gap-3 mb-4'>
                  <div class='p-2 icon-badge-indigo'>
                    <svg class='w-5 h-5' fill='none' stroke='currentColor' viewBox='0 0 24 24'>
                      <path
                        stroke-linecap='round'
                        stroke-linejoin='round'
                        stroke-width='2'
                        d='M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z'></path>
                    </svg>
                  </div>
                  <div>
                    <h2 class='text-2xl font-outfit text-dark dark:text-light'>Deadline Countdown</h2>
                    <p class='text-text-muted dark:text-custom-gray-300 text-sm'>
                      Set a date, share the link, watch the clock behave
                    </p>
                  </div>
                </div>
                <DeadlineCountdown />
              </div>
            </div>
          </div>
        </div>
      </div>

  <script slot='scripts' is:inline>
      function showToolInCategory(category, toolId) {
        const firstPill = document.querySelector(`[data-category="${category}"].pill-button`);
        const requestedPill = toolId
          ? document.querySelector(`[data-category="${category}"].pill-button[data-tool="${toolId}"]`)
          : null;
        const activePill = requestedPill || firstPill;
        if (!activePill) return;

        const categoryPills = document.querySelectorAll(`[data-category="${category}"].pill-button`);
        categoryPills.forEach((pill) => pill.classList.remove('active'));

        const categoryTools = document.querySelectorAll(`[data-category="${category}"].tool-panel`);
        categoryTools.forEach((tool) => tool.classList.add('hidden'));

        activePill.classList.add('active');
        const activeToolId = activePill.getAttribute('data-tool');
        const activeTool = document.getElementById(`tool-${activeToolId}`);
        if (activeTool) activeTool.classList.remove('hidden');
        if (activeToolId) window.ensureToolInit?.(activeToolId);
      }

      function showFirstToolInCategory(category) {
        showToolInCategory(category);
      }

      window.onPageLoad?.('tools-tabs', () => {
        const tabButtons = document.querySelectorAll('.tab-button');
        const tabPanels = document.querySelectorAll('.tab-panel');
        const pillButtons = document.querySelectorAll('.pill-button');
        if (!tabButtons.length) return;

        const handlers = [];

        const params = new URLSearchParams(window.location.search);
        const requestedTool = params.get('tool');
        const requestedPill = requestedTool
          ? document.querySelector(`.pill-button[data-tool="${requestedTool}"]`)
          : null;
        const initialCategory = requestedPill?.getAttribute('data-category') || 'development';

        tabButtons.forEach((button) => {
          button.classList.remove('active');
          button.setAttribute('aria-selected', 'false');
        });
        const activeTab = document.querySelector(`[data-tab="${initialCategory}"]`);
        if (activeTab) {
          activeTab.classList.add('active');
          activeTab.setAttribute('aria-selected', 'true');
        }
        tabPanels.forEach((panel) => panel.classList.add('hidden'));
        document.getElementById(`panel-${initialCategory}`)?.classList.remove('hidden');

        tabButtons.forEach((button) => {
          const onTabClick = () => {
            const targetTab = button.getAttribute('data-tab');
            const targetPanel = document.getElementById(`panel-${targetTab}`);

            tabButtons.forEach((btn) => {
              btn.classList.remove('active');
              btn.setAttribute('aria-selected', 'false');
            });
            tabPanels.forEach((panel) => panel.classList.add('hidden'));

            button.classList.add('active');
            button.setAttribute('aria-selected', 'true');
            targetPanel?.classList.remove('hidden');
            showFirstToolInCategory(targetTab);
          };
          button.addEventListener('click', onTabClick);
          handlers.push({ el: button, type: 'click', fn: onTabClick });
        });

        pillButtons.forEach((button) => {
          const onPillClick = () => {
            const targetTool = button.getAttribute('data-tool');
            const category = button.getAttribute('data-category');

            document.querySelectorAll(`[data-category="${category}"].pill-button`).forEach((pill) => {
              pill.classList.remove('active');
            });
            document.querySelectorAll(`[data-category="${category}"].tool-panel`).forEach((tool) => {
              tool.classList.add('hidden');
            });

            button.classList.add('active');
            const targetToolPanel = document.getElementById(`tool-${targetTool}`);
            if (targetToolPanel) targetToolPanel.classList.remove('hidden');
            if (targetTool) window.ensureToolInit?.(targetTool);
          };
          button.addEventListener('click', onPillClick);
          handlers.push({ el: button, type: 'click', fn: onPillClick });
        });

        tabButtons.forEach((button, index) => {
          const onKeydown = (e) => {
            if (e.key !== 'ArrowRight' && e.key !== 'ArrowLeft') return;
            e.preventDefault();
            const nextIndex =
              e.key === 'ArrowRight'
                ? (index + 1) % tabButtons.length
                : (index - 1 + tabButtons.length) % tabButtons.length;
            tabButtons[nextIndex].focus();
            tabButtons[nextIndex].click();
          };
          button.addEventListener('keydown', onKeydown);
          handlers.push({ el: button, type: 'keydown', fn: onKeydown });
        });

        showToolInCategory(initialCategory, requestedTool);

        return () => {
          handlers.forEach(({ el, type, fn }) => el.removeEventListener(type, fn));
        };
      });
  </script>
</BaseLayout>
