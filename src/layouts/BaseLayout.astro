---
import MetaHead from '@components/general/MetaHead.astro';
import Layout from './Layout.astro';
import type { IMetaHead } from '@types';

interface Props extends IMetaHead {
  jsonLd?: Record<string, unknown>;
}

const { title, description, ogImageUrl, jsonLd } = Astro.props as Props;
---

<!doctype html>
<html lang='en'>
  <head>
    <MetaHead title={title} description={description} ogImageUrl={ogImageUrl} jsonLd={jsonLd} />
  </head>

  <body>
    <!-- Must run before any other inline scripts that call onPageLoad / ensureToolInit -->
    <script is:inline>
      (function () {
        const getPreferredTheme = () => {
          const currentTheme = document.documentElement.getAttribute('data-theme');
          if (currentTheme === 'light' || currentTheme === 'dark') return currentTheme;

          try {
            const storedTheme = window.localStorage.getItem('theme');
            if (storedTheme === 'light' || storedTheme === 'dark') return storedTheme;
          } catch {
            // Ignore storage errors and fall back to the system preference.
          }

          return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        };

        const applyThemeToDocument = (doc, theme) => {
          doc.documentElement.setAttribute('data-theme', theme);
          const themeColor = theme === 'dark' ? '#080b14' : '#f8fafc';
          doc.querySelector('meta[name="theme-color"]')?.setAttribute('content', themeColor);
        };

        if (!window.__themeTransitionBound) {
          window.__themeTransitionBound = true;
          window.__navTransitionActive = false;

          document.addEventListener('astro:before-swap', (event) => {
            window.__navTransitionActive = true;
            const theme = getPreferredTheme();
            applyThemeToDocument(event.newDocument, theme);
          });

          document.addEventListener('astro:after-swap', () => {
            const theme = getPreferredTheme();
            applyThemeToDocument(document, theme);

            const navbar = document.getElementById('navbar');
            if (navbar) {
              navbar.classList.add('navbar-skip-transition');
              navbar.classList.toggle('is-scrolled', window.scrollY > 0);
              requestAnimationFrame(() => {
                requestAnimationFrame(() => navbar.classList.remove('navbar-skip-transition'));
              });
            }

            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                window.__navTransitionActive = false;
              });
            });
          });
        }

        if (window.onPageLoad) return;

        const cleanups = new Map();

        window.onPageLoad = function (key, fn) {
          const run = function () {
            const prev = cleanups.get(key);
            if (prev) prev();
            const result = fn();
            if (typeof result === 'function') cleanups.set(key, result);
            else cleanups.delete(key);
          };

          if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', run);
          } else {
            run();
          }

          document.addEventListener('astro:page-load', run);
        };

        window.toolInits = window.toolInits || {};
        window.__mountedTools = window.__mountedTools || new Set();
        window.__pendingToolInits = window.__pendingToolInits || [];

        window.ensureToolInit = function (toolId) {
          if (window.__mountedTools.has(toolId)) return;

          if (!window.toolInits[toolId]) {
            if (!window.__pendingToolInits.includes(toolId)) {
              window.__pendingToolInits.push(toolId);
            }
            return;
          }

          window.__mountedTools.add(toolId);
          window.toolInits[toolId]();
        };
      })();
    </script>

    <Layout>
      <slot />
    </Layout>
    <slot name='scripts' />
  </body>
</html>
