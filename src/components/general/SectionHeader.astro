---
interface Props {
  title: string;
  subtitle: string;
  as?: 'h1' | 'h2';
  class?: string;
}

const { title, subtitle, as = 'h2', class: className = '' } = Astro.props;
const Tag = as;
const subtitleClass =
  as === 'h1'
    ? 'text-lg text-text-muted dark:text-custom-gray mt-2 max-w-2xl'
    : 'text-sm text-text-muted dark:text-custom-gray mt-1 max-w-xs';
---

<div class:list={['section-header', className]}>
  <Tag class='dark:text-light leading-[1.2]'>{title}</Tag>
  <p class={subtitleClass}>{subtitle}</p>
</div>
