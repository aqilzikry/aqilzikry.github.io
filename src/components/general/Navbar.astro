---
import { info } from '@data';
import { createLogo } from '@utils';
---

<header
  id='navbar'
  class='navbar-header sticky top-4 z-50 glass-surface rounded-brand container flex items-center justify-between'
  transition:persist
>
  <a class='navbar-logo text-2xl dark:text-light font-semibold dark:font-semibold font-outfit' href='/'>{createLogo(info.name)}.</a>
  <nav>
    <ul class='flex items-center'>
      <li>
        <a class='navbar-link p-2 md:p-3 dark:text-light block text-sm md:text-lg' href='/#about'>About</a>
      </li>
      <li>
        <a class='navbar-link p-2 md:p-3 dark:text-light block text-sm md:text-lg' href='/#experience'>Experience</a>
      </li>
      <li>
        <a class='navbar-link hidden sm:block p-2 md:p-3 dark:text-light text-sm md:text-lg' href='/#education'>Education</a>
      </li>
      <li>
        <a class='navbar-link p-2 md:p-3 dark:text-light block text-sm md:text-lg' href='/projects'>Projects</a>
      </li>
      <li>
        <a class='navbar-link p-2 md:p-3 dark:text-light block text-sm md:text-lg' href='/tools'>Tools</a>
      </li>
      <li>
        <button
          aria-label='theme-button'
          id='theme-button'
          class='navbar-theme-btn dark:text-light rounded-control p-2 sm:p-4 ml-2 surface-muted'></button>
      </li>
    </ul>
  </nav>
</header>

<script is:inline>
  window.onPageLoad?.('navbar', () => {
    const moon = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-moon"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>`;
    const sun = `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="feather feather-sun"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>`;

    const themeButton = document.getElementById('theme-button');
    const browserTheme = document.querySelector('[name="theme-color"]');
    const navbar = document.getElementById('navbar');
    if (!themeButton || !navbar) return;

    const getThemeColor = () => {
      const rgb = getComputedStyle(document.documentElement).getPropertyValue('--color-surface').trim();
      return rgb ? `rgb(${rgb})` : '#f8fafc';
    };

    const getTheme = () => {
      const currentTheme = document.documentElement.getAttribute('data-theme');
      if (currentTheme === 'light' || currentTheme === 'dark') return currentTheme;

      try {
        const storedTheme = window.localStorage.getItem('theme');
        if (storedTheme === 'light' || storedTheme === 'dark') return storedTheme;
      } catch {
        // Ignore storage errors and fall back to the system preference.
      }

      return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
    };

    let lastAppliedTheme = null;

    const applyTheme = (theme) => {
      const prevDocTheme = document.documentElement.getAttribute('data-theme');
      const prevBtnHtml = themeButton.innerHTML;
      const btnHasIcon = Boolean(prevBtnHtml.trim());
      const docThemeChanged = prevDocTheme !== theme;
      const iconForTheme = theme === 'dark' ? sun : moon;
      const iconNeedsUpdate = !btnHasIcon || prevBtnHtml !== iconForTheme;

      if (!docThemeChanged && !iconNeedsUpdate) {
        lastAppliedTheme = theme;
        return;
      }

      if (docThemeChanged) {
        document.documentElement.setAttribute('data-theme', theme);
      }

      if (iconNeedsUpdate) {
        themeButton.innerHTML = iconForTheme;
      }

      themeButton.setAttribute('aria-pressed', String(theme === 'dark'));
      themeButton.setAttribute('aria-label', `Switch to ${theme === 'dark' ? 'light' : 'dark'} theme`);
      if (browserTheme) browserTheme.content = getThemeColor();

      lastAppliedTheme = theme;
    };

    applyTheme(getTheme());

    const darkModeHandler = () => {
      const nextTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      applyTheme(nextTheme);

      try {
        window.localStorage.setItem('theme', nextTheme);
      } catch {
        // Theme still applies for this page even if persistence is unavailable.
      }
    };

    const toggleNavbarShrink = (instant = false) => {
      const shouldScroll = window.scrollY > 0;

      if (instant) navbar.classList.add('navbar-skip-transition');
      navbar.classList.toggle('is-scrolled', shouldScroll);
      if (instant) {
        requestAnimationFrame(() => {
          requestAnimationFrame(() => navbar.classList.remove('navbar-skip-transition'));
        });
      }
    };

    themeButton.addEventListener('click', darkModeHandler);
    const onScroll = () => toggleNavbarShrink(Boolean(window.__navTransitionActive));
    window.addEventListener('scroll', onScroll, { passive: true });
    toggleNavbarShrink(true);

    return () => {
      themeButton.removeEventListener('click', darkModeHandler);
      window.removeEventListener('scroll', onScroll);
    };
  });
</script>
