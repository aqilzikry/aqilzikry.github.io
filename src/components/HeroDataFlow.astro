<div class="hero-data-flow" data-hero-data-flow aria-label="Animated data-flow visualization">
  <div class="hero-data-flow__stage">
    <canvas data-flow-canvas></canvas>
  </div>
  <div class="flow-orbit-label flow-orbit-label--sql">
    <span>Data</span>
    <strong>reliable storage</strong>
  </div>
  <div class="flow-orbit-label flow-orbit-label--api">
    <span>Services</span>
    <strong>clean interfaces</strong>
  </div>
  <div class="flow-orbit-label flow-orbit-label--insights">
    <span>Insights</span>
    <strong>useful dashboards</strong>
  </div>
</div>

<style>
  .hero-data-flow {
    position: relative;
    isolation: isolate;
    z-index: 2;
    width: 100%;
    height: clamp(22rem, 39vw, 31rem);
    margin-inline: auto;
    overflow: visible;
  }

  .hero-data-flow__stage {
    position: absolute;
    inset: -8% -10% -8% -14%;
    z-index: 0;
    pointer-events: none;
    -webkit-mask-image: radial-gradient(
      ellipse 120% 108% at 54% 50%,
      #000 46%,
      rgb(0 0 0 / 0.72) 58%,
      transparent 80%
    );
    mask-image: radial-gradient(
      ellipse 120% 108% at 54% 50%,
      #000 46%,
      rgb(0 0 0 / 0.72) 58%,
      transparent 80%
    );
  }

  .hero-data-flow__stage::before {
    position: absolute;
    inset: 10% 8% 10% 0;
    z-index: -1;
    pointer-events: none;
    content: "";
    background:
      radial-gradient(circle at 48% 46%, rgb(var(--color-accent) / 0.08), transparent 42%),
      radial-gradient(circle at 78% 36%, rgb(var(--color-violet) / 0.055), transparent 34%),
      radial-gradient(circle at 28% 64%, rgb(var(--color-success) / 0.05), transparent 34%);
    filter: blur(24px);
  }

  .hero-data-flow canvas {
    display: block;
    width: 100%;
    height: 100%;
    pointer-events: auto;
    touch-action: none;
  }

  .flow-orbit-label {
    position: absolute;
    z-index: 2;
    display: grid;
    gap: 0.125rem;
    min-width: 6.75rem;
    padding: 0.5rem 0.625rem;
    border: 1px solid rgb(var(--color-border-soft) / 0.62);
    border-radius: 0.75rem;
    background: rgb(var(--color-surface-glass) / 0.84);
    box-shadow: 0 14px 36px rgb(0 0 0 / 0.32);
    backdrop-filter: blur(14px);
    transform: translate3d(var(--label-x, 0), var(--label-y, 0), 0);
    transition: transform 0.15s ease-out;
  }

  .flow-orbit-label span,
  .flow-orbit-label strong {
    color: rgb(var(--color-text-strong));
    line-height: 1.1;
  }

  .flow-orbit-label span {
    color: rgb(var(--color-text-muted));
    font-family: Archivo, sans-serif;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .flow-orbit-label strong {
    font-family: "Space Grotesk", Archivo, sans-serif;
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.01em;
  }

  .flow-orbit-label--sql {
    top: 66%;
    left: 4%;
  }

  .flow-orbit-label--api {
    top: 30%;
    right: 15%;
  }

  .flow-orbit-label--insights {
    right: 0;
    bottom: 8%;
  }

  @media (max-width: 1023px) {
    .hero-data-flow {
      height: clamp(19rem, 62vw, 26rem);
    }

    .hero-data-flow__stage {
      inset: -4% -6%;
      -webkit-mask-image: radial-gradient(
        ellipse 104% 94% at 50% 50%,
        #000 52%,
        rgb(0 0 0 / 0.75) 64%,
        transparent 86%
      );
      mask-image: radial-gradient(
        ellipse 104% 94% at 50% 50%,
        #000 52%,
        rgb(0 0 0 / 0.75) 64%,
        transparent 86%
      );
    }

    .hero-data-flow canvas {
      pointer-events: none;
      touch-action: auto;
    }
  }

  @media (max-width: 520px) {
    .hero-data-flow {
      height: clamp(18rem, 78vw, 22rem);
    }

    .flow-orbit-label {
      min-width: 6rem;
      padding: 0.45rem 0.55rem;
    }

    .flow-orbit-label strong {
      font-size: 0.72rem;
    }

    .flow-orbit-label--sql {
      top: 67%;
      left: 0;
    }

    .flow-orbit-label--api {
      top: 26%;
      right: 12%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .flow-orbit-label {
      transition: none;
    }
  }
</style>

<script>
  import { initHeroDataFlow } from "../scripts/hero-data-flow";

  const bootHeroDataFlow = () => {
    const cleanup = initHeroDataFlow();

    if (typeof cleanup === "function") {
      document.addEventListener("astro:before-swap", cleanup, { once: true });
    }
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", bootHeroDataFlow, { once: true });
  } else {
    bootHeroDataFlow();
  }
</script>
