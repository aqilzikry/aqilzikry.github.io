---
import type { IHeroProps } from '@types';
import SocialLinks from '@components/general/SocialLinks.astro';
import HeroDataFlow from './HeroDataFlow.astro';

interface Props extends IHeroProps {}

const { name, jobDescription, about, resumeUrl } = Astro.props;
---

<section id='about' class='hero-section scroll-mt-28'>
  <div class='hero-copy'>
    <p class='dark:text-light text-sm text-text-muted dark:text-custom-gray'>Hey, I'm</p>
    <h1 class='leading-[1.2]' transition:animate='slide'>
      {name}
    </h1>
    <p class='dark:text-light text-lg font-medium mb-3'>{jobDescription}</p>
    <p class='dark:text-light text-base text-text-muted dark:text-custom-gray mb-8 max-w-2xl'>
      {about}
    </p>
    <div class='flex flex-wrap items-center gap-4 mb-10'>
      <div class='grid grid-cols-3 gap-4 sm:w-80'>
        <SocialLinks />
      </div>
      {
        resumeUrl && (
          <a
            href={resumeUrl}
            download
            class='btn-primary inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium'
          >
            <svg class='h-4 w-4' viewBox='0 0 24 24' fill='none' stroke='currentColor' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' aria-hidden='true'>
              <path d='M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4' />
              <polyline points='7 10 12 15 17 10' />
              <line x1='12' y1='15' x2='12' y2='3' />
            </svg>
            Download CV
          </a>
        )
      }
    </div>
  </div>
  <div class='hero-visual' aria-hidden='true'>
    <HeroDataFlow />
  </div>
</section>

<style>
  .hero-section {
    display: grid;
    grid-template-columns: minmax(0, 1.03fr) minmax(20rem, 0.78fr);
    gap: clamp(1rem, 2.5vw, 3rem);
    align-items: center;
    min-height: min(35rem, calc(100vh - 9rem));
    padding-top: clamp(2.75rem, 6vw, 4.75rem);
    padding-bottom: clamp(1rem, 3vw, 2rem);
    overflow: visible;
  }

  .hero-copy {
    position: relative;
    z-index: 1;
  }

  .hero-visual {
    position: relative;
    z-index: 0;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-width: 0;
    overflow: visible;
    margin-left: clamp(-1.75rem, -3vw, -0.25rem);
  }

  @media (max-width: 1023px) {
    .hero-section {
      grid-template-columns: 1fr;
      min-height: auto;
      padding-top: clamp(4.75rem, 14vw, 6.5rem);
      gap: 1.25rem;
    }

    .hero-visual {
      order: 2;
      justify-content: center;
      margin-left: 0;
    }
  }
</style>
