---
import SectionHeader from '@components/general/SectionHeader.astro';
import { info } from '@data';

const technologies = info.technologies || [];
const sortedTechnologies = [...technologies].sort((a, b) => a.name.localeCompare(b.name));
const targetTechForDarkFill = ['.NET', 'SQL', 'MongoDB', 'GitHub', 'NextJS', 'Tailwind CSS'];
---

<section class='my-16'>
  <SectionHeader
    title='Tech Stack'
    subtitle='What I reach for when building stuff'
    class='w-[15rem] mt-16 mb-8'
  />
  <div class='grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-8'>
    {
      sortedTechnologies
        .map((tech) => {
          const isTargetIcon = targetTechForDarkFill.includes(tech.name);
          // Base classes for the icon wrapper
          let iconWrapperClasses = [
            'w-16 h-16 mb-2 flex items-center justify-center transition-all duration-300 ease-in-out',
          ];

          if (isTargetIcon) {
            // Add text color classes for target icons, responsive to dark mode
            iconWrapperClasses.push('text-text-body dark:text-light');
          }

          return (
            <div class='group surface-card subtle-gradient-hover flex flex-col items-center p-4 min-h-[10rem] hover:scale-105 hover:-translate-y-2'>
              {tech.icon && tech.icon.startsWith('<svg') ? (
                <div
                  class:list={[...iconWrapperClasses, 'group-hover:scale-110 group-hover:rotate-3']}
                  set:html={tech.icon}
                />
              ) : (
                <div class='w-16 h-16 mb-2 bg-surface-muted dark:bg-surface-muted rounded-full flex items-center justify-center text-xs text-text-muted dark:text-custom-gray-300 transition-all duration-300 ease-in-out group-hover:scale-110 group-hover:bg-accent-soft dark:group-hover:bg-accent-soft'>
                  [ICON]
                </div>
              )}
              <p class='text-center dark:text-light mt-auto transition-all duration-300 ease-in-out group-hover:text-accent group-hover:font-medium'>
                {tech.name}
              </p>
            </div>
          );
        })
    }
  </div>
</section>
