---
import SectionHeader from "./SectionHeader.astro";
import { experience } from "@content/portfolio";
---

<section class="section-shell" id="experience">
  <SectionHeader
    eyebrow="Experience"
    title="Enterprise systems, payroll platforms, and banking dashboards."
    copy="A career path shaped by full-stack delivery, database performance, secure APIs, and practical internal products."
  />

  <div class="timeline">
    {
      experience.map((item) => (
        <article class="timeline-item">
          <div class="timeline-meta">
            <span>{item.period}</span>
            {item.status && <strong>{item.status}</strong>}
          </div>
          <div class="timeline-card">
            <div class="timeline-card-header">
              <div>
                <h3>{item.company}</h3>
                <p>{item.role} / {item.location}</p>
              </div>
            </div>
            <p class="timeline-summary">{item.summary}</p>
            <ul>
              {item.highlights.map((highlight) => <li>{highlight}</li>)}
            </ul>
            <div class="tag-row">
              {item.stack.map((tag) => <span>{tag}</span>)}
            </div>
          </div>
        </article>
      ))
    }
  </div>
</section>
