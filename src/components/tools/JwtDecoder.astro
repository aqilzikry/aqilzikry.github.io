---
// src/components/tools/JwtDecoder.astro
---

<div class='space-y-6'>
  <div>
    <label for='jwtInput' class='block text-lg font-medium text-dark dark:text-light'>JWT Token:</label>
    <textarea
      id='jwtInput'
      name='jwtInput'
      rows='4'
      placeholder='Paste your JWT token here (eyJhbGciOiJ...)'
      class='mt-1 block w-full px-3 py-2 form-control sm:text-sm font-mono resize-y'
    ></textarea>
  </div>

  <div class='grid grid-cols-2 md:grid-cols-3 gap-4'>
    <button type='button' id='jwtDecodeBtn' class='px-4 py-2 btn-primary'>Decode</button>
    <button type='button' id='jwtClearBtn' class='px-4 py-2 btn-danger'>Clear</button>
    <button type='button' id='jwtCopyBtn' class='px-4 py-2 btn-violet'>Copy Payload</button>
  </div>

  <div id='jwtStatusMessage' class='hidden p-3 rounded-control'></div>

  <div id='jwtExpirationBanner' class='hidden p-3 rounded-control'></div>

  <div class='grid gap-6 md:grid-cols-2'>
    <div>
      <label for='jwtHeaderOutput' class='block text-lg font-medium text-dark dark:text-light'>Header:</label>
      <textarea
        id='jwtHeaderOutput'
        name='jwtHeaderOutput'
        rows='6'
        readonly
        class='mt-1 block w-full px-3 py-2 form-control sm:text-sm font-mono resize-y'
      ></textarea>
    </div>
    <div>
      <label for='jwtPayloadOutput' class='block text-lg font-medium text-dark dark:text-light'>Payload:</label>
      <textarea
        id='jwtPayloadOutput'
        name='jwtPayloadOutput'
        rows='6'
        readonly
        class='mt-1 block w-full px-3 py-2 form-control sm:text-sm font-mono resize-y'
      ></textarea>
    </div>
  </div>

  <div>
    <label for='jwtSignatureOutput' class='block text-lg font-medium text-dark dark:text-light'>Signature:</label>
    <textarea
      id='jwtSignatureOutput'
      name='jwtSignatureOutput'
      rows='2'
      readonly
      class='mt-1 block w-full px-3 py-2 form-control sm:text-sm font-mono resize-y'
    ></textarea>
  </div>
</div>

<script>
  import { copyWithButtonFeedback } from '../../scripts/clipboard';
  import { base64UrlDecode } from '../../scripts/encoding';
  import { createStatusHelpers } from '../../scripts/status';

  function initJwtDecoder() {
    const jwtInput = document.getElementById('jwtInput') as HTMLTextAreaElement | null;
    const jwtHeaderOutput = document.getElementById('jwtHeaderOutput') as HTMLTextAreaElement | null;
    const jwtPayloadOutput = document.getElementById('jwtPayloadOutput') as HTMLTextAreaElement | null;
    const jwtSignatureOutput = document.getElementById('jwtSignatureOutput') as HTMLTextAreaElement | null;
    const jwtStatusMessage = document.getElementById('jwtStatusMessage');
    const jwtExpirationBanner = document.getElementById('jwtExpirationBanner');
    const jwtDecodeBtn = document.getElementById('jwtDecodeBtn') as HTMLButtonElement | null;
    const jwtClearBtn = document.getElementById('jwtClearBtn') as HTMLButtonElement | null;
    const jwtCopyBtn = document.getElementById('jwtCopyBtn') as HTMLButtonElement | null;

    if (
      !jwtInput ||
      !jwtHeaderOutput ||
      !jwtPayloadOutput ||
      !jwtSignatureOutput ||
      !jwtStatusMessage ||
      !jwtExpirationBanner ||
      !jwtDecodeBtn ||
      !jwtClearBtn ||
      !jwtCopyBtn
    ) {
      return;
    }

    const status = createStatusHelpers(jwtStatusMessage);

    const hideExpirationBanner = () => {
      jwtExpirationBanner.className = 'hidden p-3 rounded-control';
    };

    function decodeJwt(token: string) {
      const parts = token.split('.');
      if (parts.length !== 3) {
        throw new Error('Invalid JWT format. Expected 3 parts separated by dots.');
      }

      const [headerPart, payloadPart, signaturePart] = parts;

      let header, payload;
      try {
        header = JSON.parse(base64UrlDecode(headerPart));
      } catch {
        throw new Error('Failed to decode JWT header.');
      }

      try {
        payload = JSON.parse(base64UrlDecode(payloadPart));
      } catch {
        throw new Error('Failed to decode JWT payload.');
      }

      return { header, payload, signature: signaturePart };
    }

    function checkExpiration(payload: Record<string, unknown>) {
      if (typeof payload.exp !== 'number') return null;

      const expDate = new Date(payload.exp * 1000);
      const now = new Date();
      const isExpired = expDate < now;

      return { expDate, isExpired };
    }

    jwtDecodeBtn.addEventListener('click', () => {
      const token = jwtInput.value.trim();
      status.hide();
      hideExpirationBanner();

      if (!token) {
        status.show('Please enter a JWT token to decode.', 'error');
        return;
      }

      try {
        const { header, payload, signature } = decodeJwt(token);

        jwtHeaderOutput.value = JSON.stringify(header, null, 2);
        jwtPayloadOutput.value = JSON.stringify(payload, null, 2);
        jwtSignatureOutput.value = signature;

        const expiration = checkExpiration(payload);
        if (expiration) {
          const formatted = expiration.expDate.toLocaleString();
          if (expiration.isExpired) {
            jwtExpirationBanner.textContent = `Token expired on ${formatted}`;
            jwtExpirationBanner.className = 'p-3 rounded-control status-error';
          } else {
            jwtExpirationBanner.textContent = `Token expires on ${formatted}`;
            jwtExpirationBanner.className = 'p-3 rounded-control status-info';
          }
        }

        const alg = header.alg || 'unknown';
        status.show(`Decoded successfully (algorithm: ${alg})`, 'success');
      } catch (error) {
        jwtHeaderOutput.value = '';
        jwtPayloadOutput.value = '';
        jwtSignatureOutput.value = '';
        status.show((error as Error).message, 'error');
      }
    });

    jwtClearBtn.addEventListener('click', () => {
      jwtInput.value = '';
      jwtHeaderOutput.value = '';
      jwtPayloadOutput.value = '';
      jwtSignatureOutput.value = '';
      status.hide();
      hideExpirationBanner();
    });

    jwtCopyBtn.addEventListener('click', async () => {
      const payload = jwtPayloadOutput.value.trim();
      if (!payload) {
        status.show('No payload to copy.', 'error');
        return;
      }

      const copied = await copyWithButtonFeedback(payload, jwtCopyBtn, 'Copy Payload');
      status.show(copied ? 'Payload copied to clipboard!' : 'Failed to copy to clipboard.', copied ? 'success' : 'error');
    });
  }

  import { registerToolInit } from '../../scripts/tools-registry';
  registerToolInit('jwt-decoder', initJwtDecoder);
</script>
