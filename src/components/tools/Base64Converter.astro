---
// src/components/tools/Base64Converter.astro
---

<div class='space-y-6'>
  <div>
    <label class='block text-lg font-medium text-dark dark:text-light mb-3'>Mode:</label>
    <div class='flex space-x-4'>
      <label class='flex items-center'>
        <input
          type='radio'
          name='base64Mode'
          value='encode'
          id='base64EncodeMode'
          checked
          class='mr-2 text-accent focus:ring-accent'
        />
        <span class='text-dark dark:text-light'>Encode</span>
      </label>
      <label class='flex items-center'>
        <input
          type='radio'
          name='base64Mode'
          value='decode'
          id='base64DecodeMode'
          class='mr-2 text-accent focus:ring-accent'
        />
        <span class='text-dark dark:text-light'>Decode</span>
      </label>
    </div>
  </div>

  <div>
    <label for='base64Input' class='block text-lg font-medium text-dark dark:text-light'>Input:</label>
    <textarea
      id='base64Input'
      name='base64Input'
      rows='6'
      placeholder='Enter text to encode or Base64 to decode...'
      class='mt-1 block w-full px-3 py-2 form-control sm:text-sm font-mono resize-y'
    ></textarea>
  </div>

  <div class='grid grid-cols-2 md:grid-cols-3 gap-4'>
    <button type='button' id='base64ConvertBtn' class='px-4 py-2 btn-primary'>Convert</button>
    <button type='button' id='base64ClearBtn' class='px-4 py-2 btn-danger'>Clear</button>
    <button type='button' id='base64CopyBtn' class='px-4 py-2 btn-violet'>Copy Output</button>
  </div>

  <div id='base64StatusMessage' class='hidden p-3 rounded-control'></div>

  <div>
    <label for='base64Output' class='block text-lg font-medium text-dark dark:text-light'>Output:</label>
    <textarea
      id='base64Output'
      name='base64Output'
      rows='6'
      readonly
      class='mt-1 block w-full px-3 py-2 form-control sm:text-sm font-mono resize-y'
    ></textarea>
  </div>
</div>

<script>
  import { copyWithButtonFeedback } from '../../scripts/clipboard';
  import { base64Decode, base64Encode } from '../../scripts/encoding';
  import { createStatusHelpers } from '../../scripts/status';

  function initBase64Converter() {
    const base64Input = document.getElementById('base64Input') as HTMLTextAreaElement | null;
    const base64Output = document.getElementById('base64Output') as HTMLTextAreaElement | null;
    const base64StatusMessage = document.getElementById('base64StatusMessage');
    const base64ConvertBtn = document.getElementById('base64ConvertBtn') as HTMLButtonElement | null;
    const base64ClearBtn = document.getElementById('base64ClearBtn') as HTMLButtonElement | null;
    const base64CopyBtn = document.getElementById('base64CopyBtn') as HTMLButtonElement | null;
    const base64EncodeMode = document.getElementById('base64EncodeMode') as HTMLInputElement | null;
    const base64DecodeMode = document.getElementById('base64DecodeMode') as HTMLInputElement | null;

    if (
      !base64Input ||
      !base64Output ||
      !base64StatusMessage ||
      !base64ConvertBtn ||
      !base64ClearBtn ||
      !base64CopyBtn ||
      !base64EncodeMode ||
      !base64DecodeMode
    ) {
      return;
    }

    const status = createStatusHelpers(base64StatusMessage);

    const updateConvertButtonLabel = () => {
      base64ConvertBtn.textContent = base64EncodeMode.checked ? 'Encode' : 'Decode';
    };

    base64ConvertBtn.addEventListener('click', () => {
      const input = base64Input.value;
      status.hide();

      if (!input) {
        status.show('Please enter some text to convert.', 'error');
        return;
      }

      try {
        if (base64EncodeMode.checked) {
          base64Output.value = base64Encode(input);
          status.show('Encoded to Base64 successfully!', 'success');
        } else {
          base64Output.value = base64Decode(input);
          status.show('Decoded from Base64 successfully!', 'success');
        }
      } catch (error) {
        base64Output.value = '';
        status.show(
          base64EncodeMode.checked
            ? `Encoding failed: ${(error as Error).message}`
            : 'Decoding failed: invalid Base64 input.',
          'error'
        );
      }
    });

    base64ClearBtn.addEventListener('click', () => {
      base64Input.value = '';
      base64Output.value = '';
      status.hide();
    });

    base64CopyBtn.addEventListener('click', async () => {
      const output = base64Output.value;
      if (!output) {
        status.show('No output to copy.', 'error');
        return;
      }

      const copied = await copyWithButtonFeedback(output, base64CopyBtn, 'Copy Output');
      status.show(copied ? 'Output copied to clipboard!' : 'Failed to copy to clipboard.', copied ? 'success' : 'error');
    });

    base64EncodeMode.addEventListener('change', () => {
      updateConvertButtonLabel();
      base64Output.value = '';
      status.hide();
    });

    base64DecodeMode.addEventListener('change', () => {
      updateConvertButtonLabel();
      base64Output.value = '';
      status.hide();
    });

    updateConvertButtonLabel();
  }

  import { registerToolInit } from '../../scripts/tools-registry';
  registerToolInit('base64-converter', initBase64Converter);
</script>
