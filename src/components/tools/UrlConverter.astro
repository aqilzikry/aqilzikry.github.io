---
// src/components/tools/UrlConverter.astro
---

<div class='space-y-6'>
  <div>
    <label class='block text-lg font-medium text-dark dark:text-light mb-3'>Mode:</label>
    <div class='flex space-x-4'>
      <label class='flex items-center'>
        <input
          type='radio'
          name='urlMode'
          value='encode'
          id='urlEncodeMode'
          checked
          class='mr-2 text-accent focus:ring-accent'
        />
        <span class='text-dark dark:text-light'>Encode</span>
      </label>
      <label class='flex items-center'>
        <input
          type='radio'
          name='urlMode'
          value='decode'
          id='urlDecodeMode'
          class='mr-2 text-accent focus:ring-accent'
        />
        <span class='text-dark dark:text-light'>Decode</span>
      </label>
    </div>
  </div>

  <div>
    <label for='urlInput' class='block text-lg font-medium text-dark dark:text-light'>Input:</label>
    <textarea
      id='urlInput'
      name='urlInput'
      rows='6'
      placeholder='Enter text to encode or URL-encoded text to decode...'
      class='mt-1 block w-full px-3 py-2 form-control sm:text-sm font-mono resize-y'
    ></textarea>
  </div>

  <div class='grid grid-cols-2 md:grid-cols-3 gap-4'>
    <button type='button' id='urlConvertBtn' class='px-4 py-2 btn-primary'>Convert</button>
    <button type='button' id='urlClearBtn' class='px-4 py-2 btn-danger'>Clear</button>
    <button type='button' id='urlCopyBtn' class='px-4 py-2 btn-violet'>Copy Output</button>
  </div>

  <div id='urlStatusMessage' class='hidden p-3 rounded-control'></div>

  <div>
    <label for='urlOutput' class='block text-lg font-medium text-dark dark:text-light'>Output:</label>
    <textarea
      id='urlOutput'
      name='urlOutput'
      rows='6'
      readonly
      class='mt-1 block w-full px-3 py-2 form-control sm:text-sm font-mono resize-y'
    ></textarea>
  </div>
</div>

<script>
  import { copyWithButtonFeedback } from '../../scripts/clipboard';
  import { createStatusHelpers } from '../../scripts/status';

  function initUrlConverter() {
    const urlInput = document.getElementById('urlInput') as HTMLTextAreaElement | null;
    const urlOutput = document.getElementById('urlOutput') as HTMLTextAreaElement | null;
    const urlStatusMessage = document.getElementById('urlStatusMessage');
    const urlConvertBtn = document.getElementById('urlConvertBtn') as HTMLButtonElement | null;
    const urlClearBtn = document.getElementById('urlClearBtn') as HTMLButtonElement | null;
    const urlCopyBtn = document.getElementById('urlCopyBtn') as HTMLButtonElement | null;
    const urlEncodeMode = document.getElementById('urlEncodeMode') as HTMLInputElement | null;
    const urlDecodeMode = document.getElementById('urlDecodeMode') as HTMLInputElement | null;

    if (
      !urlInput ||
      !urlOutput ||
      !urlStatusMessage ||
      !urlConvertBtn ||
      !urlClearBtn ||
      !urlCopyBtn ||
      !urlEncodeMode ||
      !urlDecodeMode
    ) {
      return;
    }

    const status = createStatusHelpers(urlStatusMessage);

    const updateConvertButtonLabel = () => {
      urlConvertBtn.textContent = urlEncodeMode.checked ? 'Encode' : 'Decode';
    };

    urlConvertBtn.addEventListener('click', () => {
      const input = urlInput.value;
      status.hide();

      if (!input) {
        status.show('Please enter some text to convert.', 'error');
        return;
      }

      try {
        if (urlEncodeMode.checked) {
          urlOutput.value = encodeURIComponent(input);
          status.show('URL encoded successfully!', 'success');
        } else {
          urlOutput.value = decodeURIComponent(input);
          status.show('URL decoded successfully!', 'success');
        }
      } catch {
        urlOutput.value = '';
        status.show('Decoding failed: invalid URL-encoded input.', 'error');
      }
    });

    urlClearBtn.addEventListener('click', () => {
      urlInput.value = '';
      urlOutput.value = '';
      status.hide();
    });

    urlCopyBtn.addEventListener('click', async () => {
      const output = urlOutput.value;
      if (!output) {
        status.show('No output to copy.', 'error');
        return;
      }

      const copied = await copyWithButtonFeedback(output, urlCopyBtn, 'Copy Output');
      status.show(copied ? 'Output copied to clipboard!' : 'Failed to copy to clipboard.', copied ? 'success' : 'error');
    });

    urlEncodeMode.addEventListener('change', () => {
      updateConvertButtonLabel();
      urlOutput.value = '';
      status.hide();
    });

    urlDecodeMode.addEventListener('change', () => {
      updateConvertButtonLabel();
      urlOutput.value = '';
      status.hide();
    });

    updateConvertButtonLabel();
  }

  import { registerToolInit } from '../../scripts/tools-registry';
  registerToolInit('url-converter', initUrlConverter);
</script>
