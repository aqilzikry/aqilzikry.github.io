---
// src/components/tools/JsonXmlValidator.astro
---

<div class='space-y-6'>
  <!-- Format Selection -->
  <div>
    <label class='block text-lg font-medium text-dark dark:text-light mb-3'>Format:</label>
    <div class='flex space-x-4'>
      <label class='flex items-center'>
        <input
          type='radio'
          name='format'
          value='json'
          id='jsonFormat'
          checked
          class='mr-2 text-accent focus:ring-accent'
        />
        <span class='text-dark dark:text-light'>JSON</span>
      </label>
      <label class='flex items-center'>
        <input type='radio' name='format' value='xml' id='xmlFormat' class='mr-2 text-accent focus:ring-accent' />
        <span class='text-dark dark:text-light'>XML</span>
      </label>
    </div>
  </div>

  <!-- View Mode Selection -->
  <div>
    <label class='block text-lg font-medium text-dark dark:text-light mb-3'>View Mode:</label>
    <div class='flex space-x-4'>
      <label class='flex items-center'>
        <input
          type='radio'
          name='viewMode'
          value='normal'
          id='normalMode'
          checked
          class='mr-2 text-accent focus:ring-accent'
        />
        <span class='text-dark dark:text-light'>Normal</span>
      </label>
      <label class='flex items-center'>
        <input type='radio' name='viewMode' value='tree' id='treeMode' class='mr-2 text-accent focus:ring-accent' />
        <span class='text-dark dark:text-light'>Tree</span>
      </label>
    </div>
  </div>

  <!-- Input Area -->
  <div>
    <label for='inputData' class='block text-lg font-medium text-dark dark:text-light'>Input Data:</label>
    <textarea
      id='inputData'
      name='inputData'
      rows='8'
      placeholder='Paste your JSON or XML here...'
      class='mt-1 block w-full px-3 py-2 form-control sm:text-sm font-mono resize-y'
    ></textarea>
  </div>

  <!-- Action Buttons -->
  <div class='grid grid-cols-2 md:grid-cols-4 gap-4'>
    <button
      type='button'
      id='validateBtn'
      class='px-4 py-2 btn-primary'
    >
      Validate
    </button>
    <button
      type='button'
      id='formatBtn'
      class='px-4 py-2 btn-success'
    >
      Format
    </button>
    <button
      type='button'
      id='clearBtn'
      class='px-4 py-2 btn-danger'
    >
      Clear
    </button>
    <button
      type='button'
      id='copyBtn'
      class='px-4 py-2 btn-violet'
    >
      Copy Output
    </button>
  </div>

  <!-- Status Message -->
  <div id='statusMessage' class='hidden p-3 rounded-control'></div>

  <!-- Output Area -->
  <div>
    <label for='outputData' class='block text-lg font-medium text-dark dark:text-light'>Output:</label>
    <div id='normalOutput' class='mt-1'>
      <textarea
        id='outputData'
        name='outputData'
        rows='8'
        readonly
        class='block w-full px-3 py-2 form-control sm:text-sm font-mono resize-y'
      ></textarea>
    </div>
    <div id='treeOutput' class='mt-1 hidden'>
      <div
        id='treeContainer'
        class='block w-full p-3 form-control min-h-32 max-h-96 overflow-auto font-mono'
      >
      </div>
    </div>
  </div>
</div>

<script>
  import { copyWithButtonFeedback } from '../../scripts/clipboard';
  import { createStatusHelpers } from '../../scripts/status';
  import { createTreeNode } from '../../scripts/tree';

  function initJsonXmlValidator() {
    const inputData = document.getElementById('inputData') as HTMLTextAreaElement | null;
    const outputData = document.getElementById('outputData') as HTMLTextAreaElement | null;
    const treeContainer = document.getElementById('treeContainer') as HTMLElement | null;
    const normalOutput = document.getElementById('normalOutput') as HTMLElement | null;
    const treeOutput = document.getElementById('treeOutput') as HTMLElement | null;
    const statusMessage = document.getElementById('statusMessage');
    const validateBtn = document.getElementById('validateBtn') as HTMLButtonElement | null;
    const formatBtn = document.getElementById('formatBtn') as HTMLButtonElement | null;
    const clearBtn = document.getElementById('clearBtn') as HTMLButtonElement | null;
    const copyBtn = document.getElementById('copyBtn') as HTMLButtonElement | null;
    const jsonFormat = document.getElementById('jsonFormat') as HTMLInputElement | null;
    const xmlFormat = document.getElementById('xmlFormat') as HTMLInputElement | null;
    const normalMode = document.getElementById('normalMode') as HTMLInputElement | null;
    const treeMode = document.getElementById('treeMode') as HTMLInputElement | null;

    if (
      !inputData ||
      !outputData ||
      !treeContainer ||
      !normalOutput ||
      !treeOutput ||
      !statusMessage ||
      !validateBtn ||
      !formatBtn ||
      !clearBtn ||
      !copyBtn ||
      !jsonFormat ||
      !xmlFormat ||
      !normalMode ||
      !treeMode
    ) {
      return;
    }

    const status = createStatusHelpers(statusMessage);

    const updateViewMode = () => {
      if (treeMode.checked) {
        normalOutput.classList.add('hidden');
        treeOutput.classList.remove('hidden');
      } else {
        normalOutput.classList.remove('hidden');
        treeOutput.classList.add('hidden');
      }
    };

    const getErrorMessage = (error: unknown): string =>
      error instanceof Error ? error.message : String(error);

    function validateJson(jsonString: string) {
      try {
        JSON.parse(jsonString);
        return { valid: true, error: null as string | null };
      } catch (error) {
        return { valid: false, error: getErrorMessage(error) };
      }
    }

    function validateXml(xmlString: string) {
      try {
        const parser = new DOMParser();
        const doc = parser.parseFromString(xmlString, 'application/xml');
        const parserError = doc.querySelector('parsererror');
        if (parserError) {
          return { valid: false, error: parserError.textContent };
        }
        return { valid: true, error: null as string | null };
      } catch (error) {
        return { valid: false, error: getErrorMessage(error) };
      }
    }

    function formatJson(jsonString: string) {
      try {
        const parsed = JSON.parse(jsonString);
        return JSON.stringify(parsed, null, 2);
      } catch (error) {
        throw new Error(`JSON formatting error: ${getErrorMessage(error)}`);
      }
    }

    function formatXml(xmlString: string) {
      try {
        const parser = new DOMParser();
        const xmlDoc = parser.parseFromString(xmlString, 'application/xml');
        const parserError = xmlDoc.querySelector('parsererror');
        if (parserError) {
          throw new Error(parserError.textContent);
        }

        const serializer = new XMLSerializer();
        let formatted = serializer.serializeToString(xmlDoc);

        // Basic XML formatting
        formatted = formatted.replace(/></g, '>\n<');
        const lines = formatted.split('\n');
        let indent = 0;
        const indentedLines = lines.map((line) => {
          if (line.match(/<\/\w/)) {
            indent--;
          }
          const indentedLine = '  '.repeat(Math.max(0, indent)) + line;
          if (line.match(/<\w[^>]*[^\/]>$/)) {
            indent++;
          }
          return indentedLine;
        });

        return indentedLines.join('\n');
      } catch (error) {
        throw new Error(`XML formatting error: ${getErrorMessage(error)}`);
      }
    }

    const createCollapsibleJsonTree = (obj: unknown, level = 0): HTMLDivElement => {
      if (obj === null) {
        const { nodeDiv } = createTreeNode('<span class="syntax-muted">null</span>', level);
        return nodeDiv;
      } else if (typeof obj === 'boolean') {
        const { nodeDiv } = createTreeNode(`<span class="syntax-value">${obj}</span>`, level);
        return nodeDiv;
      } else if (typeof obj === 'number') {
        const { nodeDiv } = createTreeNode(`<span class="syntax-success">${obj}</span>`, level);
        return nodeDiv;
      } else if (typeof obj === 'string') {
        const { nodeDiv } = createTreeNode(`<span class="syntax-error">"${obj}"</span>`, level);
        return nodeDiv;
      } else if (Array.isArray(obj)) {
        const { nodeDiv, childrenDiv } = createTreeNode(
          `<span class="syntax-muted">Array (${obj.length} items)</span>`,
          level,
          true,
          level < 2
        );

        obj.forEach((item, index) => {
          const itemContainer = document.createElement('div');
          itemContainer.className = 'flex items-start';
          itemContainer.style.marginLeft = '20px';

          const indexLabel = document.createElement('span');
          indexLabel.className = 'syntax-muted mr-2 min-w-8';
          indexLabel.textContent = `[${index}]`;

          const itemNode = createCollapsibleJsonTree(item, level + 1);

          itemContainer.appendChild(indexLabel);
          if (itemNode) itemContainer.appendChild(itemNode);
          childrenDiv?.appendChild(itemContainer);
        });

        return nodeDiv;
      } else if (typeof obj === 'object') {
        const keys = Object.keys(obj);
        const { nodeDiv, childrenDiv } = createTreeNode(
          `<span class="syntax-muted">Object (${keys.length} properties)</span>`,
          level,
          true,
          level < 2
        );

        keys.forEach((key) => {
          const propertyContainer = document.createElement('div');
          propertyContainer.className = 'flex items-start';
          propertyContainer.style.marginLeft = '20px';

          const keyLabel = document.createElement('span');
          keyLabel.className = 'syntax-key mr-2 font-semibold';
          keyLabel.textContent = `"${key}":`;

          const valueNode = createCollapsibleJsonTree((obj as Record<string, unknown>)[key], level + 1);

          propertyContainer.appendChild(keyLabel);
          propertyContainer.appendChild(valueNode);
          childrenDiv?.appendChild(propertyContainer);
        });

        return nodeDiv;
      }

      const { nodeDiv } = createTreeNode('<span class="syntax-muted">undefined</span>', level);
      return nodeDiv;
    };

    const createCollapsibleXmlTree = (node: Element, level = 0): HTMLDivElement => {
        const tagName = node.tagName.toLowerCase();
        let content = `<span class="syntax-value">&lt;${tagName}</span>`;

        // Add attributes
        if (node.attributes.length > 0) {
          for (let attr of node.attributes) {
            content += ` <span class="syntax-string">${attr.name}</span>=<span class="syntax-error">"${attr.value}"</span>`;
          }
        }

        content += `<span class="syntax-value">&gt;</span>`;

        const hasChildren = node.childNodes.length > 0;
        const textContent = Array.from(node.childNodes)
          .filter((child): child is ChildNode => child.nodeType === Node.TEXT_NODE)
          .map((child) => child.textContent?.trim() ?? '')
          .filter((text) => text)
          .join(' ');

        if (!hasChildren || (hasChildren && !textContent && node.childElementCount === 0)) {
          content = content.replace('&gt;', '/&gt;');
          const { nodeDiv } = createTreeNode(content, level);
          return nodeDiv;
        }

        const { nodeDiv, childrenDiv } = createTreeNode(content, level, true, level < 3);

        // Add text content if any
        if (textContent) {
          const textNode = document.createElement('div');
          textNode.style.marginLeft = '20px';
          textNode.innerHTML = `<span class="ml-3"></span><span class="syntax-muted">${textContent}</span>`;
          childrenDiv?.appendChild(textNode);
        }

        // Add child elements
        Array.from(node.childNodes)
          .filter((child): child is Element => child.nodeType === Node.ELEMENT_NODE)
          .forEach((child) => {
            const childNode = createCollapsibleXmlTree(child, level + 1);
            childrenDiv?.appendChild(childNode);
          });

        // Add closing tag
        const closingDiv = document.createElement('div');
        closingDiv.innerHTML = `<span class="ml-3"></span><span class="syntax-value">&lt;/${tagName}&gt;</span>`;
        childrenDiv?.appendChild(closingDiv);

        return nodeDiv;
    };

    const generateTreeView = (data: string, format: 'json' | 'xml') => {
      treeContainer.innerHTML = '';

      try {
        if (format === 'json') {
          const parsed = JSON.parse(data);
          const treeNode = createCollapsibleJsonTree(parsed);
          treeContainer.appendChild(treeNode);
        } else if (format === 'xml') {
          const parser = new DOMParser();
          const xmlDoc = parser.parseFromString(data, 'application/xml');
          const parserError = xmlDoc.querySelector('parsererror');
          if (parserError) {
            throw new Error(parserError.textContent ?? 'Invalid XML');
          }
          const treeNode = createCollapsibleXmlTree(xmlDoc.documentElement);
          treeContainer.appendChild(treeNode);
        }

        addTreeToggleHandlers();
      } catch (error) {
        treeContainer.innerHTML = `<span class="syntax-error">Error generating tree view: ${getErrorMessage(error)}</span>`;
      }
    };

    const addTreeToggleHandlers = () => {
      const toggles = treeContainer.querySelectorAll('.tree-toggle');
      toggles.forEach((toggle) => {
        toggle.addEventListener('click', (e) => {
          e.stopPropagation();
          const nodeId = toggle.getAttribute('data-node');
          if (!nodeId) return;
          const childrenDiv = document.getElementById(nodeId);

          if (childrenDiv) {
            const isVisible = childrenDiv.style.display !== 'none';
            childrenDiv.style.display = isVisible ? 'none' : 'block';
            toggle.textContent = isVisible ? '▶' : '▼';
          }
        });
      });
    };

    // Event listeners
    validateBtn.addEventListener('click', () => {
      const data = inputData.value.trim();
      if (!data) {
        status.show('Please enter some data to validate.', 'error');
        return;
      }

      const format = jsonFormat.checked ? 'json' : 'xml';
      let result;

      if (format === 'json') {
        result = validateJson(data);
      } else {
        result = validateXml(data);
      }

      if (result.valid) {
        status.show(`Valid ${format.toUpperCase()}!`, 'success');
        outputData.value = data;
        if (treeMode.checked) {
          generateTreeView(data, format);
        }
      } else {
        status.show(`Invalid ${format.toUpperCase()}: ${result.error}`, 'error');
        outputData.value = '';
        treeContainer.innerHTML = '';
      }
    });

    formatBtn.addEventListener('click', () => {
      const data = inputData.value.trim();
      if (!data) {
        status.show('Please enter some data to format.', 'error');
        return;
      }

      const format = jsonFormat.checked ? 'json' : 'xml';

      try {
        let formatted;
        if (format === 'json') {
          formatted = formatJson(data);
        } else {
          formatted = formatXml(data);
        }

        outputData.value = formatted;
        status.show(`${format.toUpperCase()} formatted successfully!`, 'success');

        if (treeMode.checked) {
          generateTreeView(formatted, format);
        }
      } catch (error) {
        status.show((error as Error).message, 'error');
        outputData.value = '';
        treeContainer.innerHTML = '';
      }
    });

    clearBtn.addEventListener('click', () => {
      inputData.value = '';
      outputData.value = '';
      treeContainer.innerHTML = '';
      status.hide();
    });

    copyBtn.addEventListener('click', async () => {
      const textToCopy = treeMode.checked ? treeContainer.textContent : outputData.value;

      if (!textToCopy?.trim()) {
        status.show('No output to copy.', 'error');
        return;
      }

      const copied = await copyWithButtonFeedback(textToCopy, copyBtn, 'Copy Output');
      status.show(copied ? 'Output copied to clipboard!' : 'Failed to copy to clipboard.', copied ? 'success' : 'error');
    });

    // View mode change listeners
    normalMode.addEventListener('change', updateViewMode);
    treeMode.addEventListener('change', () => {
      updateViewMode();
      const data = outputData.value.trim();
      if (data && treeMode.checked) {
        const format = jsonFormat.checked ? 'json' : 'xml';
        generateTreeView(data, format);
      }
    });

    // Format change listener
    document.querySelectorAll('input[name="format"]').forEach((radio) => {
      radio.addEventListener('change', () => {
        status.hide();
        outputData.value = '';
        treeContainer.innerHTML = '';
      });
    });

    // Initialize view mode
    updateViewMode();
  }

  // Initialize on page load
  import { registerToolInit } from '../../scripts/tools-registry';
  registerToolInit('json-xml-validator', initJsonXmlValidator);
</script>
